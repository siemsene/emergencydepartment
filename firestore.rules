rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "siemsene@gmail.com";
    }

    match /instructors/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /sessions/{sessionId} {
      // Anyone can read sessions (players need to look up by code)
      allow read: if true;
      // Only authenticated instructors can write to sessions
      allow create: if isSignedIn();
      allow update: if isSignedIn() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'playerCount', 'staffingReadyCount', 'turnReadyCount', 'syncEpoch', 'currentHour', 'status', 'pauseAfterTurn', 'endedAt'])
      );
      allow delete: if isSignedIn();
    }

    match /sessions/{sessionId}/roster/{lockId} {
      // Lightweight roster locks for join deduplication
      allow read, write: if true;
    }
    match /players/{playerId} {
      // Anyone can read players
      allow read: if true;
      // Anyone can create a player (joining a session)
      allow create: if true;
      // Anyone can update a player, but only allowed fields unless signed in
      allow update: if isSignedIn() || (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['gameState', 'isConnected', 'lastSeen'])
      );
      // Only authenticated users (instructors) can delete players
      allow delete: if isSignedIn();
    }
  }
}


