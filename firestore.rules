rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "siemsene@gmail.com";
    }

    function instructorExists(userId) {
      return exists(/databases/$(database)/documents/instructors/$(userId));
    }

    function instructorDoc(userId) {
      return get(/databases/$(database)/documents/instructors/$(userId));
    }

    function isApprovedInstructor(userId) {
      return isSignedIn() &&
        request.auth.uid == userId &&
        instructorExists(userId) &&
        instructorDoc(userId).data.approved == true &&
        instructorDoc(userId).data.role == "instructor";
    }

    function sessionExists(sessionId) {
      return exists(/databases/$(database)/documents/sessions/$(sessionId));
    }

    function sessionDoc(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId));
    }

    function canManageSessionForInstructor(instructorId) {
      return isAdmin() ||
        (isApprovedInstructor(request.auth.uid) && request.auth.uid == instructorId);
    }

    function canManageSession(sessionId) {
      return sessionExists(sessionId) &&
        canManageSessionForInstructor(sessionDoc(sessionId).data.instructorId);
    }

    function canManagePlayer(playerSessionId) {
      return isAdmin() ||
        (sessionExists(playerSessionId) &&
          isApprovedInstructor(request.auth.uid) &&
          sessionDoc(playerSessionId).data.instructorId == request.auth.uid);
    }

    function validApprovalStatus(status) {
      return status == "pending" || status == "approved" || status == "rejected";
    }

    function validInstructorCreate(userId) {
      return isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.keys().hasAll([
          "email", "name", "role", "approved", "approvalStatus",
          "sessionsCreated", "createdAt"
        ]) &&
        request.resource.data.keys().hasOnly([
          "email", "name", "role", "approved", "approvalStatus",
          "organization", "sessionsCreated", "createdAt", "approvedAt"
        ]) &&
        request.resource.data.role == "instructor" &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.sessionsCreated == 0 &&
        request.resource.data.createdAt == request.time &&
        validApprovalStatus(request.resource.data.approvalStatus) &&
        (
          (
            !isAdmin() &&
            request.resource.data.approved == false &&
            request.resource.data.approvalStatus == "pending" &&
            !request.resource.data.keys().hasAny(["approvedAt"])
          ) ||
          (
            isAdmin() &&
            request.resource.data.approved == true &&
            request.resource.data.approvalStatus == "approved" &&
            request.resource.data.approvedAt == request.time
          )
        );
    }

    function validOwnInstructorUpdate(userId) {
      return isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastActive", "sessionsCreated"
        ]) &&
        (
          request.resource.data.sessionsCreated == resource.data.sessionsCreated ||
          request.resource.data.sessionsCreated == resource.data.sessionsCreated + 1
        ) &&
        (
          !request.resource.data.keys().hasAny(["lastActive"]) ||
          request.resource.data.lastActive == request.time
        );
    }

    function validSessionCreate() {
      return request.resource.data.keys().hasAll([
        "id", "code", "instructorId", "name", "createdAt", "expiresAt",
        "status", "currentHour", "parameters", "arrivals", "players",
        "maxPlayers", "playerCount", "staffingReadyCount",
        "turnReadyCount", "syncEpoch", "usePregenerated", "asyncMode"
      ]) &&
        request.resource.data.keys().hasOnly([
          "id", "code", "instructorId", "name", "createdAt", "expiresAt",
          "status", "currentHour", "parameters", "arrivals", "players",
          "maxPlayers", "playerCount", "staffingReadyCount",
          "turnReadyCount", "syncEpoch", "usePregenerated", "asyncMode",
          "startedAt", "endedAt", "pauseAfterTurn"
        ]) &&
        request.resource.data.id is string &&
        request.resource.data.code is string &&
        request.resource.data.code.size() == 6 &&
        request.resource.data.instructorId == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.status == "setup" &&
        request.resource.data.currentHour == 0 &&
        request.resource.data.players.size() == 0 &&
        request.resource.data.playerCount == 0 &&
        request.resource.data.staffingReadyCount == 0 &&
        request.resource.data.turnReadyCount == 0 &&
        request.resource.data.syncEpoch == 0 &&
        request.resource.data.maxPlayers > 0 &&
        request.resource.data.maxPlayers <= 150 &&
        request.resource.data.arrivals.size() == 0 &&
        request.resource.data.usePregenerated == false &&
        request.resource.data.asyncMode == false;
    }

    function validPublicStaffingReadyIncrement() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "staffingReadyCount"
        ]) &&
        resource.data.status == "staffing" &&
        request.resource.data.staffingReadyCount == resource.data.staffingReadyCount + 1 &&
        request.resource.data.staffingReadyCount <= resource.data.playerCount;
    }

    function validPublicStaffingAdvance() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "staffingReadyCount", "turnReadyCount", "status", "currentHour", "syncEpoch"
        ]) &&
        resource.data.status == "staffing" &&
        request.resource.data.status == "sequencing" &&
        request.resource.data.currentHour == 1 &&
        request.resource.data.syncEpoch == resource.data.syncEpoch + 1 &&
        request.resource.data.turnReadyCount == 0 &&
        request.resource.data.staffingReadyCount == resource.data.playerCount;
    }

    function validPublicTurnReadyIncrement() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "turnReadyCount"
        ]) &&
        resource.data.status == "sequencing" &&
        request.resource.data.turnReadyCount == resource.data.turnReadyCount + 1 &&
        request.resource.data.turnReadyCount <= resource.data.playerCount;
    }

    function validPublicTurnAdvance() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "turnReadyCount", "currentHour", "syncEpoch"
        ]) &&
        resource.data.status == "sequencing" &&
        resource.data.currentHour < 24 &&
        request.resource.data.currentHour == resource.data.currentHour + 1 &&
        request.resource.data.turnReadyCount == 0 &&
        request.resource.data.syncEpoch == resource.data.syncEpoch + 1;
    }

    function validPublicTurnPause() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "turnReadyCount", "status", "pauseAfterTurn", "syncEpoch"
        ]) &&
        resource.data.status == "sequencing" &&
        resource.data.pauseAfterTurn == true &&
        request.resource.data.status == "paused" &&
        request.resource.data.pauseAfterTurn == false &&
        request.resource.data.turnReadyCount == 0 &&
        request.resource.data.syncEpoch == resource.data.syncEpoch + 1;
    }

    function validPublicTurnComplete() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "turnReadyCount", "status", "currentHour", "syncEpoch", "endedAt"
        ]) &&
        resource.data.status == "sequencing" &&
        resource.data.currentHour == 24 &&
        request.resource.data.status == "completed" &&
        request.resource.data.currentHour == 24 &&
        request.resource.data.turnReadyCount == 0 &&
        request.resource.data.syncEpoch == resource.data.syncEpoch + 1 &&
        request.resource.data.endedAt == request.time;
    }

    function validPublicPlayerUpdate() {
      return !isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["gameState", "isConnected", "lastSeen"]) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.sessionId == resource.data.sessionId &&
        request.resource.data.joinedAt == resource.data.joinedAt &&
        request.resource.data.lastSeen == request.time;
    }

    match /instructors/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if validInstructorCreate(userId);
      allow update: if isAdmin() || validOwnInstructorUpdate(userId);
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      // Public reads are still required for students to join by session code and
      // continue the game without Firebase Auth.
      allow read: if true;
      allow create: if isApprovedInstructor(request.auth.uid) &&
        request.resource.data.instructorId == request.auth.uid &&
        validSessionCreate();
      allow update: if canManageSessionForInstructor(resource.data.instructorId) ||
        validPublicStaffingReadyIncrement() ||
        validPublicStaffingAdvance() ||
        validPublicTurnReadyIncrement() ||
        validPublicTurnAdvance() ||
        validPublicTurnPause() ||
        validPublicTurnComplete();
      allow delete: if canManageSessionForInstructor(resource.data.instructorId);
    }

    match /sessions/{sessionId}/roster/{lockId} {
      allow read: if canManageSession(sessionId);
      allow create: if false;
      allow update: if false;
      allow delete: if canManageSession(sessionId);
    }

    match /players/{playerId} {
      // Public reads are still required for anonymous students reconnecting and
      // receiving game state snapshots.
      allow read: if true;
      allow create: if false;
      allow update: if canManagePlayer(resource.data.sessionId) || validPublicPlayerUpdate();
      allow delete: if canManagePlayer(resource.data.sessionId);
    }
  }
}
